$Common = "../Common.ui";

Group {
  // 1. The native dark translucent overlay that dims the game world
  $Common.@PageOverlay {
    Anchor: (Top: 0, Bottom: 0, Left: 0, Right: 0);
  }

  // 2. Center the settings window on the screen
  Group {
    LayoutMode: Center;
    Anchor: (Top: 0, Bottom: 0, Left: 0, Right: 0);

    // 3. Utilize the native Container prefab for a standard Hytale UI window
    $Common.@Container #MainContainer {
      @CloseButton = true;
      Anchor: (Width: 800, Height: 850);

      #Title {
        // Use the native title text styling
        $Common.@Title {
          @Text = "Player Settings";
          @Alignment = Center;
          Anchor: (Top: 0, Bottom: 0, Left: 0, Right: 0);
        }
      }

      #Content {
        LayoutMode: Top;

        // A native decorative separator right under the title
        $Common.@PanelSeparatorFancy {
          @Anchor = (Left: 0, Right: 0);
          Anchor: (Height: 2);
        }

        // The container where Java appends SettingsCategoryItem.ui files
        Group #CategoryList {
          LayoutMode: TopScrolling;
          FlexWeight: 1;
          Anchor: (Left: 0, Right: 0);
          Padding: (Top: 15, Horizontal: 10);
        }
      }
    }
  }
}