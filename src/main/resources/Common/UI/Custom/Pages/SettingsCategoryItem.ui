$Common = "../Common.ui";

// Root group used to create "margin" (spacing) between list items safely
Group {
  Anchor: (Height: 90, Left: 0, Right: 0); // 80px button + 10px bottom gap
  Padding: (Bottom: 10);

  // The actual interactive button using Hytale's secondary button style
  Button #CategoryButton {
    LayoutMode: Left;
    Anchor: (Top: 0, Bottom: 0, Left: 0, Right: 0);
    Padding: (Left: 14, Right: 14, Vertical: 10);
    Background: $Common.@InputBoxBackground;
    OutlineColor: #93844c(0.0);
    OutlineSize: 1.5;
    Style: $Common.@SecondaryButtonStyle;


    // Icon set dynamically by Java via AssetPath
    AssetImage #CategoryIcon {
      Anchor: (Width: 50, Height: 50);
      AssetPath: "UI/Custom/Pages/DefaultSettingsIcon.png";
    }

    // Spacing between icon and text
    Group #Spacer {
      Anchor: (Width: 20);
    }

    Group #CategoryInfo {
      LayoutMode: Top;
      FlexWeight: 1;
      Anchor: (Top: 0, Bottom: 0, Right: 0);
      // Mod display name
      Label #CategoryName {
        Style: (
          ...$Common.@SubtitleStyle,
          FontSize: 24,
          VerticalAlignment: Center,
          TextColor: #ffffff
        );
        Text: "Category Placeholder";
        Padding: (Bottom: 5);
      }
    }

    // Right-arrow caret
    Group #CaretIcon {
      Background: "../Common/DropdownPressedCaret.png";
      Anchor: (Width: 28, Height: 4, Right: 4, Vertical: 0);
    }

  }
}